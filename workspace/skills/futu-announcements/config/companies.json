        "https?://newsfile\\.futunn\\.com/public/NN-PersistNoticeAttachment/[^\\s\"'<>()]+\\.(?:PDF|pdf)",
        "https?://newsfile\\.futunn\\.com/notice/[^\\s\"'<>()]+\\.(?:PDF|pdf)"
      ],
      "fallbackPdfPatterns": [
        "https?://www1?\\.hkexnews\\.hk/listedco/[^\\s\"'<>()]+\\.pdf"
      ]
    },
